# UAC AI Parser Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Secret key for session signing (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Ollama (default, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo

# Anthropic Claude (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini (optional)
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-pro

# =============================================================================
# STORAGE PATHS
# =============================================================================

# SQLite database path
DATABASE_PATH=~/.uac-ai/uac-ai.db

# Upload folder for temporary files
UPLOAD_FOLDER=~/.uac-ai/uploads

# ChromaDB vector store directory
CHROMA_PERSIST_DIR=~/.uac-ai/chroma

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask environment: development, testing, production
FLASK_ENV=development

# Enable debug mode (set to false in production)
FLASK_DEBUG=true

# CORS allowed origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# RAG CONFIGURATION
# =============================================================================

# Chunk size in tokens (default: 512)
# RAG_CHUNK_SIZE=512

# Chunk overlap in tokens (default: 50)
# RAG_CHUNK_OVERLAP=50

# Top-K results for retrieval (default: 5)
# RAG_TOP_K=5

# Hot cache size (default: 1000)
# RAG_HOT_CACHE_SIZE=1000

# Hot cache TTL in seconds (default: 3600)
# RAG_HOT_CACHE_TTL=3600

# =============================================================================
# EMBEDDING MODEL CONFIGURATION
# =============================================================================

# Embedding model for vector search (requires sentence-transformers)
# Options:
#   BAAI/bge-small-en-v1.5        - 384 dim, fast, good quality (DEFAULT)
#   BAAI/bge-base-en-v1.5         - 768 dim, slower, best quality
#   all-MiniLM-L6-v2              - 384 dim, fastest, decent quality
#   nomic-ai/nomic-embed-text-v1.5 - 768 dim, good quality, Apache 2.0
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# =============================================================================
# DOCKER-SPECIFIC SETTINGS
# =============================================================================

# When running in Docker, these paths are mounted volumes:
# DATABASE_PATH=/app/data/uac-ai.db
# UPLOAD_FOLDER=/app/data/uploads
# CHROMA_PERSIST_DIR=/app/data/chroma
