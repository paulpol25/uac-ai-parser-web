# UAC AI Parser Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Secret key for session signing (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Ollama (default, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo

# Anthropic Claude (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini (optional)
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-pro

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Auth provider: "local" (DB-backed) or "supabase" (Supabase JWT)
AUTH_PROVIDER=local

# Supabase settings (only when AUTH_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key

# =============================================================================
# STORAGE PATHS  (local dev — Docker overrides these via compose env)
# =============================================================================

# SQLite database path (used when DATABASE_URL is not set)
DATABASE_PATH=~/.uac-ai/uac-ai.db

# Upload folder for temporary files
UPLOAD_FOLDER=~/.uac-ai/uploads

# ChromaDB vector store directory
CHROMA_PERSIST_DIR=~/.uac-ai/chroma

# =============================================================================
# POSTGRESQL  (Docker / production — leave blank for local SQLite)
# =============================================================================

# Postgres credentials (start.sh auto-generates POSTGRES_PASSWORD on first run)
POSTGRES_USER=uacai
POSTGRES_PASSWORD=changeme
POSTGRES_DB=uacai

# Full connection string (Docker overrides this; leave blank for SQLite)
# DATABASE_URL=postgresql://uacai:<password>@localhost:5432/uacai

# =============================================================================
# REDIS  (optional — app degrades gracefully without it)
# =============================================================================

# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# MCP SERVER
# =============================================================================

# Auth token for MCP SSE transport (auto-generated by start.sh)
MCP_AUTH_TOKEN=
MCP_LOG_LEVEL=INFO

# Admin seed credentials (used by start.sh on first run)
ADMIN_EMAIL=admin@uac-ai.local
ADMIN_PASSWORD=changeme

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask environment: development, testing, production
FLASK_ENV=development

# Enable debug mode (set to false in production)
FLASK_DEBUG=true

# CORS allowed origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# RAG CONFIGURATION
# =============================================================================

# Chunk size in tokens (default: 512)
# RAG_CHUNK_SIZE=512

# Chunk overlap in tokens (default: 50)
# RAG_CHUNK_OVERLAP=50

# Top-K results for retrieval (default: 5)
# RAG_TOP_K=5

# Hot cache size (default: 1000)
# RAG_HOT_CACHE_SIZE=1000

# Hot cache TTL in seconds (default: 3600)
# RAG_HOT_CACHE_TTL=3600

# =============================================================================
# EMBEDDING MODEL CONFIGURATION
# =============================================================================

# Embedding model for vector search (requires sentence-transformers)
# Options:
#   BAAI/bge-small-en-v1.5        - 384 dim, fast, good quality (DEFAULT)
#   BAAI/bge-base-en-v1.5         - 768 dim, slower, best quality
#   all-MiniLM-L6-v2              - 384 dim, fastest, decent quality
#   nomic-ai/nomic-embed-text-v1.5 - 768 dim, good quality, Apache 2.0
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# =============================================================================
# CLEANUP / RETENTION
# =============================================================================

# Enable automatic cleanup of expired sessions
CLEANUP_ENABLED=true

# Run cleanup every N hours
CLEANUP_INTERVAL_HOURS=24

# Auto-delete sessions older than N days (0 = never)
SESSION_RETENTION_DAYS=30

# Warn when total storage exceeds this many MB
STORAGE_WARNING_MB=500

# =============================================================================
# DOCKER-SPECIFIC NOTES
# =============================================================================

# When running via docker-compose / start.sh, these settings are overridden:
#   DATABASE_URL    → postgresql://uacai:<pw>@database:5432/uacai
#   REDIS_URL       → redis://redis:6379/0
#   UPLOAD_FOLDER   → /app/data/uploads
#   CHROMA_PERSIST_DIR → /app/data/chroma
# Secrets (SECRET_KEY, POSTGRES_PASSWORD, MCP_AUTH_TOKEN) are auto-generated.
